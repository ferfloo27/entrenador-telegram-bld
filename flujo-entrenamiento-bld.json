        "jsCode": "// 1. Obtenemos todas las partidas que trajo Supabase\nconst historial = $input.all();\n\n// 2. Escudo: Si no hay historial\nif (historial.length === 0 || !historial[0].json.id) {\n  return [{ \n    json: { \n      mensaje_telegram: \"📊 Aún no tienes estadísticas. ¡Escribe /empezar para jugar tu primera partida!\" \n    } \n  }];\n}\n\n// 3. Variables para nuestras matemáticas\nlet partidasCompletadas = 0;\nlet partidasIncompletas = 0;\nlet aciertosTotales = 0;\nlet preguntasTotales = 0;\nlet conteoErrores = {}; // Aquí guardaremos cuántas veces falló cada par\n\n// 4. Recorremos cada partida del historial\nhistorial.forEach(item => {\n  const sesion = item.json;\n  \n  if (sesion.estado === 'finalizado') {\n    partidasCompletadas++;\n    aciertosTotales += (sesion.aciertos || 0);\n    preguntasTotales += (sesion.pares ? sesion.pares.length : 15);\n    \n    // Sumamos los errores al contador\n    if (sesion.errores && Array.isArray(sesion.errores)) {\n      sesion.errores.forEach(par => {\n        conteoErrores[par] = (conteoErrores[par] || 0) + 1;\n      });\n    }\n  } else if (sesion.estado === 'cancelado' || sesion.estado === 'abandonado') {\n    partidasIncompletas++;\n  }\n});\n\n// 5. Escudo 2: Si tiene partidas pero ninguna finalizada\nif (partidasCompletadas === 0) {\n  return [{ \n    json: { \n      mensaje_telegram: \"📊 Tienes partidas iniciadas, pero ninguna completada al 100%.\\n\\n¡Termina una ronda de 15 letras para ver tu porcentaje de acierto!\" \n    } \n  }];\n}\n\n// 6. Calculamos el porcentaje\nlet porcentaje = ((aciertosTotales / preguntasTotales) * 100).toFixed(1);\n\n// 7. Magia: Ordenamos los errores de mayor a menor para sacar el Top 3\nlet topErrores = Object.keys(conteoErrores)\n  .map(par => ({ par: par, cantidad: conteoErrores[par] }))\n  .sort((a, b) => b.cantidad - a.cantidad)\n  .slice(0, 3); // Solo tomamos los 3 primeros\n\n// 8. Formateamos el texto del Top 3\nlet textoErrores = topErrores.length > 0\n  ? topErrores.map(e => `• **${e.par}** (${e.cantidad} veces)`).join('\\n')\n  : \"¡Ninguno! Tienes una memoria perfecta. 🧠✨\";\n\n// 9. Construimos el mensaje final para Telegram\nlet mensaje = `📊 **TUS ESTADÍSTICAS BLD** 📊\\n\\n`;\nmensaje += `🎮 **Partidas completadas:** ${partidasCompletadas}\\n`;\nmensaje += `🎯 **Precisión global:** ${aciertosTotales}/${preguntasTotales} (${porcentaje}%)\\n`;\nif (partidasIncompletas > 0) {\n  mensaje += `🛑 **Partidas canceladas/abandonadas:** ${partidasIncompletas}\\n`;\n}\nmensaje += `\\n⚠️ **Tus pares más difíciles (Top 3):**\\n${textoErrores}\\n\\n`;\nmensaje += `Sigue así. ¡Escribe /empezar para otra ronda!`;\n\n// 10. Enviamos el mensaje al siguiente nodo\nreturn [{ json: { mensaje_telegram: mensaje } }];"
      },
