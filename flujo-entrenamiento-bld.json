    {
      "parameters": {
        "jsCode": "const mensajeUsuario = $('Telegram Trigger').first().json.message.text.trim().toLowerCase();\nconst entrada = $input.first();\nconst sesion = entrada ? entrada.json : null;\n\n// ÚNICO ESCUDO NECESARIO: Escribió algo que no es un comando, pero no hay sesión activa.\nif (!sesion || !sesion.pares || sesion.estado !== \"entrenando\") {\n  return [{ \n    json: { \n      error: true, \n      mensaje_telegram: \"No tienes un entrenamiento activo. 😅\\n\\nEscribe /empezar para jugar.\" \n    } \n  }];\n}\n\n// EVALUACIÓN DIRECTA Y LIMPIA\nconst pares = sesion.pares;\nlet indice = sesion.pregunta_actual;\nlet aciertos = sesion.aciertos;\nlet errores = sesion.errores || []; \n\nconst parActual = pares[indice];\nconst palabraCorrecta = parActual.palabra.trim().toLowerCase();\n\nlet esCorrecto = (mensajeUsuario === palabraCorrecta);\n\nif (esCorrecto) {\n  aciertos++; \n} else {\n  errores.push(parActual.par);\n}\n\nlet textoRespuesta = esCorrecto\n  ? `✅ ¡Correcto! Era **${parActual.palabra}**.\\n\\n`\n  : `❌ ¡Fallaste! La palabra para **${parActual.par}** era **${parActual.palabra}**.\\n\\n`;\n\nindice++; \nlet estado = sesion.estado;\n\nif (indice < pares.length) {\n  textoRespuesta += `🧠 **Pregunta ${indice + 1}/${pares.length}:**\\n¿Qué palabra es: **${pares[indice].par}**?`;\n} else {\n  estado = \"finalizado\";\n  textoRespuesta += `🎉 **¡Entrenamiento finalizado!**\\nAcertaste ${aciertos} de ${pares.length}. ¡Sigue practicando!\\n\\nEscribe /empezar para jugar de nuevo.`;\n}\n\nreturn [{\n  json: {\n    error: false,\n    id_sesion: sesion.id, \n    chat_id: sesion.chat_id,\n    estado: estado,\n    pregunta_actual: indice,\n    aciertos: aciertos,\n    errores: errores, \n    mensaje_telegram: textoRespuesta\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
