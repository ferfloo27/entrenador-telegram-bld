      "parameters": {
        "jsCode": "// Juntamos los 15 pares en una sola lista\nconst listaPares = $input.all().map(item => item.json);\n\n// Obtenemos tu Chat ID del primer nodo (¡Cambia el nombre si el tuyo es diferente!)\nconst chatId = $('Telegram Trigger').first().json.message.chat.id;\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    estado: \"entrenando\",\n    pares: listaPares,          // Guardamos la lista completa\n    pregunta_actual: 0,         // Empezamos en el índice 0 (pregunta 1)\n    aciertos: 0,\n    primer_par: listaPares[0].par // Extraemos la primera letra para preguntártela ahora mismo\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1072,
        -352
      ],
      "id": "fcb18884-ef0f-40ae-b2e3-cb0a851a445e",
